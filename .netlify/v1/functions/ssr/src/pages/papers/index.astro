---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PaperCard from '../../components/cards/PaperCard.astro';

const papers = (await getCollection('papers')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<PageLayout title="Research notes" description="Downloadable summaries, methods notes, and credibility assets for collaborators and prospective clients." eyebrow="Research">
  <section class="section pt-0">
    <div class="container-shell grid gap-6 lg:grid-cols-2">
      {papers.map((paper) => (
        <PaperCard
          href={`/papers/${paper.id}/`}
          title={paper.data.title}
          summary={paper.data.summary}
          journal={paper.data.journal}
          date={paper.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        />
      ))}
    </div>
  </section>
</PageLayout>
